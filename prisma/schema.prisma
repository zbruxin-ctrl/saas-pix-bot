// Schema principal do banco de dados
// Todos os modelos do sistema SaaS PIX Bot

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Usuário Admin do Painel ───────────────────────────────────────────────

model AdminUser {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String
  role         AdminRole @default(OPERATOR)
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("admin_users")
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
  OPERATOR
}

// ─── Usuário do Telegram ───────────────────────────────────────────────────

model TelegramUser {
  id           String    @id @default(cuid())
  telegramId   String    @unique
  username     String?
  firstName    String?
  lastName     String?
  languageCode String?
  isBlocked    Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  payments          Payment[]
  orders            Order[]
  stockReservations StockReservation[]

  @@map("telegram_users")
}

// ─── Produto / Plano ───────────────────────────────────────────────────────

model Product {
  id              String       @id @default(cuid())
  name            String
  description     String
  price           Decimal      @db.Decimal(10, 2)
  deliveryType    DeliveryType
  deliveryContent String       // texto, link, token ou JSON para múltiplos
  isActive        Boolean      @default(true)
  stock           Int?         // null = ilimitado
  // stockReserved: calculado dinamicamente via StockReservation ativas
  metadata        Json?        // dados extras (ex: dias de acesso)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  payments          Payment[]
  orders            Order[]
  stockReservations StockReservation[]

  @@map("products")
}

// DeliveryType simplificado: TEXT | LINK | FILE_MEDIA | ACCOUNT
enum DeliveryType {
  TEXT        // Mensagem de texto simples
  LINK        // Link de acesso / download
  FILE_MEDIA  // URL de imagem, vídeo ou arquivo (player embutido no bot)
  ACCOUNT     // Dados de conta em JSON (usuário/senha/token)
}

// ─── Reserva Temporária de Estoque ─────────────────────────────────────────

model StockReservation {
  id             String                  @id @default(cuid())
  productId      String
  telegramUserId String
  paymentId      String?                 @unique
  quantity       Int                     @default(1)
  status         StockReservationStatus  @default(ACTIVE)
  expiresAt      DateTime                // reserva expira em 30 min
  confirmedAt    DateTime?
  releasedAt     DateTime?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt

  product      Product      @relation(fields: [productId], references: [id])
  telegramUser TelegramUser @relation(fields: [telegramUserId], references: [id])
  payment      Payment?     @relation(fields: [paymentId], references: [id])

  @@index([productId, status])
  @@index([expiresAt, status])
  @@index([telegramUserId])
  @@map("stock_reservations")
}

enum StockReservationStatus {
  ACTIVE     // reserva ativa (aguardando pagamento)
  CONFIRMED  // pagamento aprovado, estoque definitivamente alocado
  RELEASED   // expirou ou cancelado — estoque devolvido
}

// ─── Pagamento PIX ────────────────────────────────────────────────────────

model Payment {
  id                   String        @id @default(cuid())
  telegramUserId       String
  productId            String
  mercadoPagoId        String?       @unique
  amount               Decimal       @db.Decimal(10, 2)
  status               PaymentStatus @default(PENDING)
  pixQrCode            String?       @db.Text
  pixQrCodeText        String?       @db.Text
  pixExpiresAt         DateTime?
  approvedAt           DateTime?
  cancelledAt          DateTime?
  metadata             Json?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  telegramUser      TelegramUser      @relation(fields: [telegramUserId], references: [id])
  product           Product           @relation(fields: [productId], references: [id])
  order             Order?
  webhookEvents     WebhookEvent[]
  stockReservation  StockReservation?

  @@index([telegramUserId])
  @@index([status])
  @@index([mercadoPagoId])
  @@index([pixExpiresAt, status])
  @@map("payments")
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
  EXPIRED
  REFUNDED
}

// ─── Pedido (gerado após pagamento aprovado) ───────────────────────────────

model Order {
  id             String      @id @default(cuid())
  paymentId      String      @unique
  telegramUserId String
  productId      String
  status         OrderStatus @default(PROCESSING)
  deliveredAt    DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  payment        Payment      @relation(fields: [paymentId], references: [id])
  telegramUser   TelegramUser @relation(fields: [telegramUserId], references: [id])
  product        Product      @relation(fields: [productId], references: [id])
  deliveryLogs   DeliveryLog[]
  deliveryMedias DeliveryMedia[]

  @@index([telegramUserId])
  @@map("orders")
}

enum OrderStatus {
  PROCESSING
  DELIVERED
  FAILED
  CANCELLED
}

// ─── Mídia Anexada à Entrega ───────────────────────────────────────────────
// Permite anexar imagens/vídeos (via URL) a uma entrega específica

model DeliveryMedia {
  id        String          @id @default(cuid())
  orderId   String
  url       String          @db.Text  // URL da imagem/vídeo
  mediaType DeliveryMediaType
  caption   String?         @db.Text
  sortOrder Int             @default(0)
  createdAt DateTime        @default(now())

  order Order @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@map("delivery_medias")
}

enum DeliveryMediaType {
  IMAGE  // JPG, PNG, WebP, GIF
  VIDEO  // MP4, YouTube, etc. — player embutido no bot
  FILE   // PDF, ZIP, outros
}

// ─── Log de Entrega ────────────────────────────────────────────────────────

model DeliveryLog {
  id        String            @id @default(cuid())
  orderId   String
  attempt   Int               @default(1)
  status    DeliveryLogStatus
  message   String?           @db.Text
  error     String?           @db.Text
  metadata  Json?
  createdAt DateTime          @default(now())

  order Order @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@map("delivery_logs")
}

enum DeliveryLogStatus {
  SUCCESS
  FAILED
  RETRYING
}

// ─── Evento de Webhook ────────────────────────────────────────────────────

model WebhookEvent {
  id              String             @id @default(cuid())
  provider        String             @default("mercado_pago")
  eventType       String
  externalId      String
  paymentId       String?
  rawPayload      Json
  status          WebhookEventStatus @default(RECEIVED)
  processedAt     DateTime?
  error           String?            @db.Text
  createdAt       DateTime           @default(now())

  payment Payment? @relation(fields: [paymentId], references: [id])

  @@unique([provider, externalId, eventType])
  @@index([externalId])
  @@map("webhook_events")
}

enum WebhookEventStatus {
  RECEIVED
  PROCESSING
  PROCESSED
  FAILED
  IGNORED
}
